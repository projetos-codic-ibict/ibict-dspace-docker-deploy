# ==============================================================================
# REPOSITORY CONFIGURATION
# ==============================================================================
DSPACE_BACKEND_REPO=https://github.com/DSpace/DSpace.git
DSPACE_FRONTEND_REPO=https://github.com/DSpace/dspace-angular.git

# Supports both Tags (e.g. dspace-10.0) and Branches (e.g. main, dev)
# IMPORTANT: Use compatible tags/branches
DSPACE_BACKEND_TAG=dspace-10.0
DSPACE_FRONTEND_TAG=dspace-10.0

# ==============================================================================
# FRONTEND - ANGULAR CONFIGURATION
# ==============================================================================

# Local port for the DSpace Angular frontend exposed on the host machine
DSPACE_LOCAL_UI_PORT=4000

# Connection to the public DSpace REST API endpoint
DSPACE_REST_SSL=false
DSPACE_REST_HOST=localhost
DSPACE_REST_PORT=8080
DSPACE_REST_NAMESPACE=/server

# ==============================================================================
# BACKEND - JAVA CONFIGURATION
# ==============================================================================

# Repository name displayed in the DSpace user interface
DSPACE_NAME="DSpace Repository"

# Public URL of the DSpace backend (Java REST API)
DSPACE_SERVER_URL=http://localhost:8080/server

# Public URL of the DSpace Angular frontend (homepage)
DSPACE_UI_URL=http://localhost:4000

# Local port for the DSpace REST API exposed on the host machine
DSPACE_LOCAL_REST_PORT=8080

# ==============================================================================
# INFRASTRUCTURE (POSTGRESQL DATABASE)
# ==============================================================================

POSTGRES_VERSION=17
POSTGRES_USER=dspace
# IMPORTANT: Change this password before deploying to production
POSTGRES_PASSWORD=dspace_docker

# Docker network subnet and trusted proxy ranges used by DSpace
# Change these if they conflict with existing Docker or private networks.
DSPACE_DOCKER_SUBNET=172.99.0.0/16
DSPACE_TRUSTED_IPRANGES=172.99.0


# ==============================================================================
# MIGRATION CONFIGURATION (FROM NON-DOCKER TO DOCKER)
# ==============================================================================

# Path to the old assetstore directory (e.g., /dspace/assetstore)
OLD_ASSETSTORE_PATH=/dspace/assetstore

# Path to the old local.cfg file (e.g., /dspace/config/local.cfg)
OLD_LOCAL_CFG_PATH=/dspace/config/local.cfg

# Set to true only if you intentionally want to copy legacy Solr cores.
# The recommended default is false; reindex DSpace after migration instead.
MIGRATE_SOLR_DATA=false

# Path to the old Solr cores data directories (used only when MIGRATE_SOLR_DATA=true)
OLD_SOLR_DATA_PATH=/opt/dspace_old/solr

# Path to the PostgreSQL plain text dump file (.sql)
OLD_DB_DUMP_PATH=/tmp/dspace_old_backup.sql
